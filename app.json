{
  "expo": {
    "name": "HRLeave",
    "slug": "hrleave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "hrleave",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.hrleave.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE"
      ],
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hrleave.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "HRLeave uses microphone for voice commands and audio/video calls",
        "NSSpeechRecognitionUsageDescription": "HRLeave uses speech recognition for Hey HR voice activation",
        "NSCameraUsageDescription": "HRLeave uses camera for profile photo and video calls",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "requireFullScreen": true,
      "supportsCocoaPods": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-camera",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a1a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "84b8be99-64c2-4a59-92de-1d52360aa577"
      }
    },
    "owner": "roman_92",
    "updates": {
      "url": "https://u.expo.dev/84b8be99-64c2-4a59-92de-1d52360aa577",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "hrleave",
            "project": "mobile"
          }
        }
      ]
    }
  }
}
